meta {
  name: Add Sonarr Instance
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/settings/sonarr
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Sonarr",
    "url": "http://localhost:8989",
    "api_key": "your-api-key-here"
  }
}

docs {
  Adds a new Sonarr instance.
